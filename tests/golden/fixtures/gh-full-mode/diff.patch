--- a/src/database.py
+++ b/src/database.py
@@ -5,6 +5,15 @@ from sqlalchemy import create_engine

 ENGINE = create_engine(os.environ["DATABASE_URL"])

+def bulk_insert(records: list[dict]) -> None:
+    with ENGINE.connect() as conn:
+        for record in records:
+            conn.execute(
+                "INSERT INTO events VALUES (:id, :data)",
+                {"id": record["id"], "data": record["data"]}
+            )
+        conn.commit()
